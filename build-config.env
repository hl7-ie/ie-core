# IE Core Build Configuration
# This file defines environment variables used during the IG build process
# Edit these values to customize the build for different deployment environments

# Base URL for canonical namespace - used for all identifier systems and profile URLs
# Default: https://hl7-ie.github.io/ie-core (GitHub Pages - Proof of Concept)
# Future values may include:
#   - https://hl7-ie.org (when national domain is registered)
#   - https://fhir.health.ie (alternative national option)
#   - Custom institutional domain
IE_CORE_BASE_URL=https://hl7-ie.github.io/ie-core
